# ChipotleCalc — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Required by Replit Workflow ---
PORT=5173
BASE_PATH=/

# --- Analytics (optional — add after site launch) ---
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Google Search Console Verification (optional) ---
# VITE_GSC_VERIFICATION=your-google-site-verification-token

# --- AdSense (optional — add after approval) ---
# VITE_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# --- Contact Form Backend (optional) ---
# VITE_CONTACT_FORM_ENDPOINT=https://your-form-handler.com/submit
